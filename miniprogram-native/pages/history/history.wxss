.container { padding: 20rpx; background: #f5f5f5; min-height: 100vh; }
.header { margin-bottom: 24rpx; }
.title { font-size: 40rpx; font-weight: 600; color: #1f2937; }
.subtitle { font-size: 28rpx; color: #6b7280; margin-top: 8rpx; }
.record-card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; }
.record-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.mood-badge { display: flex; align-items: center; }
.mood-emoji { font-size: 48rpx; }
.mood-intensity { font-size: 24rpx; color: #6b7280; margin-left: 16rpx; }
.record-date { font-size: 24rpx; color: #9ca3af; }
.record-event { font-size: 28rpx; color: #374151; line-height: 1.6; margin-bottom: 16rpx; display: block; }
.record-tags { display: flex; flex-wrap: wrap; }
.tag { padding: 8rpx 16rpx; background: #f3f4f6; border-radius: 16rpx; font-size: 24rpx; color: #6b7280; margin-right: 16rpx; margin-bottom: 8rpx; }
.delete-btn { color: #ef4444; font-size: 28rpx; margin-top: 16rpx; }
.empty { text-align: center; padding: 120rpx 0; }
.empty-emoji { font-size: 96rpx; }
.empty-text { font-size: 32rpx; color: #374151; margin-top: 32rpx; display: block; }
