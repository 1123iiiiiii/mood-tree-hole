<view class="container">
  <view class="header">
    <text class="title">历史记录</text>
    <text class="subtitle">共 {{records.length}} 条记录</text>
  </view>
  <view wx:for="{{records}}" wx:key="_id" class="record-card">
    <view class="record-header">
      <view class="mood-badge">
        <text class="mood-emoji">{{moodEmojis[item.mood]}}</text>
        <text class="mood-intensity">{{item.intensity}}/10</text>
      </view>
      <text class="record-date">{{item.createdAt}}</text>
    </view>
    <text wx:if="{{item.event}}" class="record-event">{{item.event}}</text>
    <view wx:if="{{item.tags && item.tags.length > 0}}" class="record-tags">
      <text wx:for="{{item.tags}}" wx:key="index" class="tag">{{item}}</text>
    </view>
    <text class="delete-btn" bindtap="deleteRecord" data-id="{{item._id}}">删除</text>
  </view>
  <view wx:if="{{records.length === 0}}" class="empty">
    <text class="empty-emoji">📝</text>
    <text class="empty-text">暂无记录</text>
  </view>
</view>
