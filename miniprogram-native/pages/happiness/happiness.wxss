.container { padding: 20rpx; background: #f5f5f5; min-height: 100vh; }
.header { margin-bottom: 24rpx; }
.title { font-size: 40rpx; font-weight: 600; color: #1f2937; }
.subtitle { font-size: 28rpx; color: #6b7280; margin-top: 8rpx; }
.add-section { display: flex; margin-bottom: 24rpx; }
.add-input { flex: 1; background: #fff; border-radius: 24rpx; padding: 24rpx; font-size: 28rpx; }
.add-btn { width: 160rpx; background: #6366f1; color: #fff; border-radius: 24rpx; margin-left: 16rpx; font-size: 28rpx; }
.list { }
.item { display: flex; align-items: center; justify-content: space-between; background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 16rpx; }
.item.completed { opacity: 0.6; }
.item-content { display: flex; align-items: center; flex: 1; }
.checkbox { width: 48rpx; height: 48rpx; border: 4rpx solid #d1d5db; border-radius: 12rpx; margin-right: 24rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #10b981; }
.checkbox.checked { background: #10b981; border-color: #10b981; color: #fff; }
.item-title { font-size: 28rpx; color: #374151; }
.item.completed .item-title { text-decoration: line-through; }
.delete-btn { color: #ef4444; font-size: 36rpx; padding: 16rpx; }
.empty { text-align: center; padding: 120rpx 0; }
.empty-emoji { font-size: 96rpx; }
.empty-text { font-size: 32rpx; color: #374151; margin-top: 32rpx; display: block; }
