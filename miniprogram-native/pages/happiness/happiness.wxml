<view class="container">
  <view class="header">
    <text class="title">小确幸清单</text>
    <text class="subtitle">完成 {{completedCount}}/{{items.length}}</text>
  </view>
  <view class="add-section">
    <input class="add-input" placeholder="添加新的小确幸..." value="{{newItem}}" bindinput="inputItem" bindconfirm="addItem"/>
    <button class="add-btn" bindtap="addItem">添加</button>
  </view>
  <view class="list">
    <view wx:for="{{items}}" wx:key="_id" class="item {{item.completed ? 'completed' : ''}}">
      <view class="item-content" bindtap="toggleComplete" data-id="{{item._id}}">
        <view class="checkbox {{item.completed ? 'checked' : ''}}">{{item.completed ? '✓' : ''}}</view>
        <text class="item-title">{{item.title}}</text>
      </view>
      <text class="delete-btn" bindtap="deleteItem" data-id="{{item._id}}">×</text>
    </view>
  </view>
  <view wx:if="{{items.length === 0}}" class="empty">
    <text class="empty-emoji">✨</text>
    <text class="empty-text">还没有小确幸</text>
  </view>
</view>
