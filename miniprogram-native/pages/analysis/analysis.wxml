<view class="container">
  <view class="time-selector">
    <view wx:for="{{presets}}" wx:key="value" class="preset {{selectedPreset === item.value ? 'active' : ''}}" bindtap="selectPreset" data-value="{{item.value}}">{{item.label}}</view>
  </view>
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-value">{{stats.totalRecords}}</text>
      <text class="stat-label">记录总数</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.avgIntensity}}</text>
      <text class="stat-label">平均强度</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.positiveRate}}%</text>
      <text class="stat-label">正向情绪</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.streakDays}}</text>
      <text class="stat-label">连续天数</text>
    </view>
  </view>
  <view class="section">
    <text class="section-title">心情曲线</text>
    <view class="chart-container">
      <view wx:for="{{records}}" wx:key="_id" class="chart-bar-wrapper">
        <view class="chart-bar" style="height: {{item.intensity * 10}}px; background: #6366f1;">
          <text class="bar-emoji">{{moodEmojis[item.mood]}}</text>
        </view>
        <text class="bar-label">{{item.createdAt}}</text>
      </view>
    </view>
  </view>
  <view wx:if="{{records.length === 0}}" class="empty">
    <text class="empty-emoji">📊</text>
    <text class="empty-text">暂无数据</text>
  </view>
</view>
