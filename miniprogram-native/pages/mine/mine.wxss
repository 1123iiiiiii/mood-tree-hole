.container { background: #f5f5f5; min-height: 100vh; }
.user-header { text-align: center; padding: 80rpx 40rpx; background: linear-gradient(to bottom, #6366f1, #8b5cf6); border-radius: 0 0 48rpx 48rpx; margin-bottom: 40rpx; }
.avatar { width: 160rpx; height: 160rpx; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 32rpx; }
.avatar-text { font-size: 80rpx; }
.username { font-size: 36rpx; font-weight: 600; color: #fff; }
.user-hint { font-size: 28rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }
.menu-card { background: #fff; border-radius: 24rpx; margin: 0 20rpx 40rpx; overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 32rpx; border-bottom: 2rpx solid #f3f4f6; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 40rpx; margin-right: 24rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #374151; }
.menu-arrow { font-size: 36rpx; color: #9ca3af; }
.app-info { text-align: center; padding: 80rpx 40rpx; }
.app-version { font-size: 28rpx; color: #374151; }
.app-tech { font-size: 24rpx; color: #9ca3af; margin-top: 8rpx; display: block; }
