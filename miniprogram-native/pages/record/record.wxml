<view class="container">
  <view class="tabs">
    <view class="tab {{activeTab === 'mood' ? 'active' : ''}}" bindtap="switchTab" data-tab="mood">选择心情</view>
    <view class="tab {{activeTab === 'event' ? 'active' : ''}}" bindtap="switchTab" data-tab="event">心情随笔</view>
  </view>

  <block wx:if="{{activeTab === 'mood'}}">
    <view class="section">
      <text class="section-title">今天的心情如何？</text>
      <view class="mood-grid">
        <view wx:for="{{app.moods}}" wx:key="value" 
              class="mood-item {{selectedMood === item.value ? 'selected' : ''}}"
              bindtap="selectMood" data-mood="{{item.value}}">
          <text class="mood-emoji">{{item.emoji}}</text>
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>

      <view wx:if="{{selectedMood}}" class="card">
        <text class="intensity-label">心情强度：{{intensity}}/10</text>
        <slider value="{{intensity}}" min="1" max="10" show-value bindchange="sliderChange"/>
      </view>

      <view wx:if="{{selectedMood}}" class="card">
        <text class="tags-label">相关标签</text>
        <view class="tags-wrap">
          <text wx:for="{{app.tags}}" wx:key="value"
                class="tag {{selectedTags.includes(item.value) ? 'selected' : ''}}"
                bindtap="toggleTag" data-tag="{{item.value}}">{{item.label}}</text>
        </view>
      </view>

      <view wx:if="{{selectedMood}}" class="card">
        <textarea class="event-input" placeholder="详细描述（可选）..." value="{{eventText}}" bindinput="inputEvent" maxlength="500"/>
      </view>

      <button wx:if="{{selectedMood}}" class="submit-btn" bindtap="submitRecord">保存记录</button>
    </view>
  </block>

  <block wx:else>
    <view class="section">
      <text class="section-title">今日随想</text>
      <textarea class="essay-input" placeholder="写下今天的故事，让心情自然流淌..." value="{{eventText}}" bindinput="inputEvent" maxlength="1000"/>

      <text wx:if="{{eventText.length > 0 && eventText.length < 10}}" class="hint-text">📝 再写一些内容（至少10个字）</text>

      <button wx:if="{{eventText.length >= 10 && !isAnalyzing && !analysisResult}}" class="analyze-btn" bindtap="analyzeEvent">💭 陪伴理解我</button>

      <view wx:if="{{isAnalyzing}}" class="analyzing">
        <text>正在分析中...</text>
      </view>

      <view wx:if="{{analysisResult && !isAnalyzing}}" class="card analysis-card">
        <view class="analysis-header">💭 AI分析</view>
        <text class="analysis-insight">{{analysisResult.insight}}</text>
        <text wx:if="{{analysisResult.reason}}" class="analysis-reason">原因：{{analysisResult.reason}}</text>
        <text wx:if="{{analysisResult.action}}" class="analysis-action">💡 {{analysisResult.action}}</text>
        <button class="submit-btn" bindtap="submitRecord">保存记录</button>
      </view>
    </view>
  </block>
</view>
