.container { padding: 20rpx; background: #f5f5f5; min-height: 100vh; }
.tabs { display: flex; background: #fff; border-radius: 12rpx; padding: 8rpx; margin-bottom: 20rpx; }
.tab { flex: 1; text-align: center; padding: 24rpx; border-radius: 8rpx; font-size: 28rpx; color: #6b7280; }
.tab.active { background: #6366f1; color: #fff; }
.section-title { font-size: 32rpx; font-weight: 600; color: #1f2937; margin-bottom: 24rpx; display: block; }
.mood-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24rpx; margin-bottom: 24rpx; }
.mood-item { display: flex; flex-direction: column; align-items: center; padding: 32rpx; background: #fff; border-radius: 24rpx; border: 4rpx solid transparent; }
.mood-item.selected { border-color: #6366f1; background: #eef2ff; }
.mood-emoji { font-size: 64rpx; margin-bottom: 8rpx; }
.mood-label { font-size: 24rpx; color: #6b7280; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; }
.intensity-label { font-size: 28rpx; color: #6b7280; margin-bottom: 16rpx; display: block; }
.tags-label { font-size: 28rpx; color: #6b7280; margin-bottom: 16rpx; display: block; }
.tags-wrap { display: flex; flex-wrap: wrap; }
.tag { padding: 12rpx 24rpx; background: #f3f4f6; border-radius: 32rpx; font-size: 24rpx; color: #6b7280; margin-right: 16rpx; margin-bottom: 16rpx; }
.tag.selected { background: #6366f1; color: #fff; }
.event-input, .essay-input { width: 100%; background: #fff; border-radius: 24rpx; padding: 32rpx; min-height: 240rpx; margin-bottom: 24rpx; box-sizing: border-box; }
.hint-text { font-size: 24rpx; color: #f59e0b; margin-bottom: 24rpx; display: block; }
.analyze-btn, .submit-btn { width: 100%; background: linear-gradient(to right, #6366f1, #8b5cf6); color: #fff; border-radius: 24rpx; padding: 28rpx; font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; border: none; }
.analyze-btn::after, .submit-btn::after { border: none; }
.analyzing { text-align: center; padding: 40rpx; color: #6b7280; }
.analysis-card { background: #f9fafb; }
.analysis-header { font-size: 32rpx; font-weight: 600; color: #6366f1; margin-bottom: 16rpx; }
.analysis-insight { font-size: 28rpx; color: #374151; line-height: 1.6; }
.analysis-reason { font-size: 24rpx; color: #f59e0b; margin-top: 16rpx; display: block; }
.analysis-action { font-size: 24rpx; color: #10b981; margin-top: 8rpx; display: block; }
