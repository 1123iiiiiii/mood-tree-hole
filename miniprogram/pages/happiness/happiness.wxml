<!--pages/happiness/happiness.wxml-->
<view class="container">
  <!-- Tab切换 -->
  <view class="tab-bar">
    <view class="tab {{activeTab === 'list' ? 'active' : ''}}" bindtap="switchTab" data-tab="list">清单</view>
    <view class="tab {{activeTab === 'recommend' ? 'active' : ''}}" bindtap="switchTab" data-tab="recommend">推荐</view>
  </view>

  <!-- 清单列表 -->
  <view wx:if="{{activeTab === 'list'}}" class="list-section">
    <view class="add-btn" bindtap="showAddModal">
      <text>+</text> 添加小事
    </view>
    
    <view class="happy-list">
      <view class="happy-item {{item.isCompleted ? 'completed' : ''}}" 
            wx:for="{{list}}" wx:key="id"
            bindtap="completeItem" data-id="{{item.id}}">
        <view class="item-left">
          <text class="check-icon">{{item.isCompleted ? '✓' : ''}}</text>
        </view>
        <view class="item-content">
          <text class="item-title">{{item.title}}</text>
          <text class="item-meta">{{item.category}} · {{item.frequency}}</text>
        </view>
        <view class="item-right">
          <text class="streak">{{item.streak}}天</text>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{list.length === 0}}">
      <text>还没有小确幸，添加一件小事吧~</text>
    </view>
  </view>

  <!-- 推荐列表 -->
  <view wx:if="{{activeTab === 'recommend'}}" class="recommend-section">
    <view class="recommend-header">
      <text class="recommend-title">根据你的喜好推荐</text>
    </view>
    
    <view class="recommend-list">
      <view class="recommend-item" wx:for="{{recommendations}}" wx:key="id"
            bindtap="addAndComplete" data-item="{{item}}">
        <text class="recommend-emoji">{{item.emoji}}</text>
        <view class="recommend-content">
          <text class="recommend-title">{{item.title}}</text>
          <text class="recommend-reason">已完成 {{item.completedCount}} 次</text>
        </view>
        <button class="add-btn-small">添加</button>
      </view>
    </view>
  </view>

  <!-- 添加弹窗 -->
  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-mask" bindtap="hideModal"></view>
    <view class="modal-content">
      <text class="modal-title">添加小确幸</text>
      <input class="modal-input" placeholder="请输入小事名称" bindinput="onTitleInput" value="{{newTitle}}" />
      <view class="category-select">
        <text>分类：</text>
        <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
          <text>{{categories[selectedCategory]}}</text>
        </picker>
      </view>
      <view class="modal-btns">
        <button class="btn-cancel" bindtap="hideModal">取消</button>
        <button class="btn-confirm" bindtap="addItem">确定</button>
      </view>
    </view>
  </view>
</view>
