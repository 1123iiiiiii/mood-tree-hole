<!--index.wxml-->
<view class="container">
  <!-- 头部欢迎 -->
  <view class="header">
    <text class="greeting">{{greeting}}</text>
    <text class="date">{{today}}</text>
  </view>

  <!-- 快捷记录卡片 -->
  <view class="quick-record-card" bindtap="goToRecord">
    <view class="card-content">
      <text class="card-title">记录此刻心情</text>
      <text class="card-desc">点击开始记录</text>
    </view>
    <text class="arrow">→</text>
  </view>

  <!-- 今日概览 -->
  <view class="section">
    <text class="section-title">今日概览</text>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{todayCount}}</text>
        <text class="stat-label">记录</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{todayMood}}</text>
        <text class="stat-label">心情</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{todayIntensity}}</text>
        <text class="stat-label">强度</text>
      </view>
    </view>
  </view>

  <!-- 最近记录 -->
  <view class="section">
    <text class="section-title">最近记录</text>
    <view class="record-list">
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="id">
        <view class="record-left">
          <text class="mood-emoji">{{item.moodEmoji}}</text>
        </view>
        <view class="record-right">
          <text class="record-mood">{{item.moodText}}</text>
          <text class="record-time">{{item.time}}</text>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{recentRecords.length === 0}}">
        <text>暂无记录，开始记录你的心情吧~</text>
      </view>
    </view>
  </view>
</view>
