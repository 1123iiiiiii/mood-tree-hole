<!--pages/history/history.wxml-->
<view class="container">
  <!-- 筛选 -->
  <view class="filter-bar">
    <picker mode="selector" range="{{moodOptions}}" bindchange="onMoodFilter">
      <text class="filter-text">{{selectedMood || '全部心情'}}</text>
    </picker>
  </view>

  <!-- 记录列表 -->
  <view class="record-list">
    <view class="record-card" wx:for="{{records}}" wx:key="id">
      <view class="card-header">
        <text class="mood-emoji">{{item.moodEmoji}}</text>
        <view class="header-info">
          <text class="mood-name">{{item.moodText}}</text>
          <text class="record-time">{{item.time}}</text>
        </view>
        <view class="intensity-badge">强度{{item.intensity}}</view>
      </view>
      <view class="card-body" wx:if="{{item.event}}">
        <text class="event-text">{{item.event}}</text>
      </view>
      <view class="card-footer">
        <view class="tag-list">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{records.length === 0}}">
      <text>暂无记录</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore && records.length > 0}}" bindtap="loadMore">
      <text>加载更多</text>
    </view>
  </view>
</view>
