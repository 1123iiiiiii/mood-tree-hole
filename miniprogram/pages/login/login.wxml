<!--pages/login/login.wxml-->
<view class="container">
  <view class="logo-section">
    <text class="logo">🌳</text>
    <text class="app-name">心情树洞</text>
    <text class="slogan">记录心情，遇见更好的自己</text>
  </view>

  <view class="form-section">
    <view class="tab-bar">
      <view class="tab {{activeTab === 'login' ? 'active' : ''}}" bindtap="switchTab" data-tab="login">登录</view>
      <view class="tab {{activeTab === 'register' ? 'active' : ''}}" bindtap="switchTab" data-tab="register">注册</view>
    </view>

    <view class="form">
      <view class="form-item">
        <input class="input" placeholder="请输入邮箱" bindinput="onEmailInput" value="{{email}}" type="email" />
      </view>
      <view class="form-item">
        <input class="input" placeholder="请输入密码" bindinput="onPasswordInput" value="{{password}}" password />
      </view>
      <view class="form-item" wx:if="{{activeTab === 'register'}}">
        <input class="input" placeholder="请输入用户名(3-20字符)" bindinput="onUsernameInput" value="{{username}}" />
      </view>
      <button class="submit-btn" bindtap="onSubmit">{{activeTab === 'login' ? '登录' : '注册'}}</button>
    </view>
  </view>
</view>
