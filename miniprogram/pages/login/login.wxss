/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 100rpx 50rpx;
}

.logo-section {
  text-align: center;
  margin-bottom: 100rpx;
}

.logo {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 20rpx;
}

.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-section {
  background: white;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
}

.tab-bar {
  display: flex;
  margin-bottom: 50rpx;
  border-bottom: 2rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 32rpx;
  color: #999;
  position: relative;
}

.tab.active {
  color: #6366f1;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #6366f1;
  border-radius: 2rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.input {
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 25rpx;
  font-size: 28rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
  margin-top: 30rpx;
}

.submit-btn:active {
  opacity: 0.8;
}
