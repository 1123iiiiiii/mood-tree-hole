<!--pages/mine/mine.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="username">{{userInfo.username}}</text>
      <text class="email">{{userInfo.email}}</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-value">{{totalRecords}}</text>
      <text class="stat-label">心情记录</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalHappiness}}</text>
      <text class="stat-label">小确幸</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{totalDays}}</text>
      <text class="stat-label">记录天数</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onExportData">
      <text class="menu-icon">📤</text>
      <text class="menu-text">导出数据</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="onImportData">
      <text class="menu-icon">📥</text>
      <text class="menu-text">导入数据</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="onClearData">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清空数据</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="logout-btn" bindtap="onLogout">退出登录</button>
</view>
